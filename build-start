#!/bin/bash

PORT=${PORT:-3002}
RUNTIME=${RUNTIME:-bun}

# Parse optional arguments
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -p|--port) PORT="$2"; shift ;;
        --bun) RUNTIME="bun" ;;
        --node) RUNTIME="node" ;;
        -h|--help) 
            echo "Usage: ./build-start [options]"
            echo "Options:"
            echo "  -p, --port <port>   Set the port (default: 3000)"
            echo "  --bun               Use bun runtime"
            echo "  --node              Use node runtime (default)"
            exit 0
            ;;
    esac
    shift
done

echo "Building and starting with $RUNTIME on port $PORT..."

if [ "$RUNTIME" = "bun" ]; then
    bun run build:bun
    PORT=$PORT bun run start:bun
else
    npm run build
    PORT=$PORT npm run start
fi
